# ── Redis ────────────────────────────────────────────────────────────────────
# Hostname for the Redis service. Inside Docker Compose this resolves via the
# shared network; use "localhost" when running outside Docker.
REDIS_HOST=redis
REDIS_PORT=6379

# Name of the Redis List used as the primary job queue (LPUSH / BRPOP)
REDIS_QUEUE_NAME=flowcore:jobs

# Name of the Redis Sorted Set used to schedule delayed retries.
# Score = Unix timestamp of when the job should be re-queued.
REDIS_DELAYED_SET=flowcore:delayed

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# Hostname for the RabbitMQ broker (dead-letter queue).
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Name of the durable RabbitMQ queue that receives permanently failed jobs.
RABBITMQ_DLQ_QUEUE=flowcore:dlq

# ── Job behaviour ─────────────────────────────────────────────────────────────
# Default maximum retry attempts before a job is routed to the DLQ.
# Can be overridden per-job in the POST /jobs request body.
MAX_RETRIES=3

# ── Worker ───────────────────────────────────────────────────────────────────
# Number of worker threads spawned per worker container.
# Each thread runs an independent BRPOP loop.
WORKER_CONCURRENCY=4

# ── Logging ──────────────────────────────────────────────────────────────────
# Structured JSON log level. Valid values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
